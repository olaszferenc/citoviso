# Citoviso environment — copy to .env (gitignored) and fill in.
# Nothing here is loaded automatically yet; src/config.ts reads these when wired up.

# Playwright / Chromium (this dev box already has ms-playwright chromium cached)
CHROMIUM_PATH=/home/mineral/.cache/ms-playwright/chromium-1228/chrome-linux64/chrome

# Database — PostgreSQL.
# Local dev uses the embedded cluster (npm run db:up) via a unix socket; leave
# DATABASE_URL empty and src/config.ts falls back to the PG* defaults below.
# Set DATABASE_URL only for prod/managed cloud (it overrides the PG* fields).
DATABASE_URL=
PGHOST=/tmp
PGPORT=5433
PGUSER=postgres
PGPASSWORD=
PGDATABASE=citoviso_dev

# Outreach email (planned)
SMTP_URL=
OUTREACH_FROM=

# Google / Maps data source (Places API + Street View Static API)
GOOGLE_MAPS_API_KEY=

# Programmable Search Engine id (Custom Search JSON API — web-search enrichment).
# Enable "Custom Search API" on the key + create a CSE with "Search the entire web".
GOOGLE_CSE_ID=

# Anthropic API key (sk-ant-...) — AI copy generation in the mock generator.
# Create one at console.anthropic.com. Without it, the generator uses template copy.
ANTHROPIC_API_KEY=

# ── Payment gateway (Slice 2) — pilot pay-link flow ─────────────────────────────
# mock (default) = local, no keys. barion = real Barion Smart Gateway.
PAYMENT_GATEWAY=mock
# Absolute base URL of THIS app (Barion validates CallbackUrl/RedirectUrl). e.g.
# https://console.example.com  (for local Barion tests use a tunnel URL).
PUBLIC_BASE_URL=
# Barion — SANDBOX first (test cards, no real money), then production.
#   sandbox: BARION_URL=https://api.test.barion.com  BARION_PAY_URL=https://secure.test.barion.com
#   prod   : BARION_URL=https://api.barion.com        BARION_PAY_URL=https://secure.barion.com
BARION_URL=https://api.test.barion.com
BARION_PAY_URL=https://secure.test.barion.com
BARION_POSKEY=
BARION_PAYEE=

# ── Invoicing (Slice 3) — auto AAM invoice on paid ──────────────────────────────
# mock (default) = local, no key. szamlazz = real Számlázz.hu Számla Agent.
# TEST account: create a #free account, enable "Tesztmód" (test invoices are free
# and NOT reported to NAV), use that account's Agent key here.
INVOICE_PROVIDER=mock
SZAMLAZZ_URL=https://www.szamlazz.hu/szamla/
SZAMLAZZ_AGENT_KEY=
