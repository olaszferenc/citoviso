# Citoviso environment — copy to .env (gitignored) and fill in.
# Nothing here is loaded automatically yet; src/config.ts reads these when wired up.

# Playwright / Chromium (this dev box already has ms-playwright chromium cached)
CHROMIUM_PATH=/home/mineral/.cache/ms-playwright/chromium-1228/chrome-linux64/chrome

# Database (planned — PostgreSQL, multi-tenant)
DATABASE_URL=

# Outreach email (planned)
SMTP_URL=
OUTREACH_FROM=

# Google / Maps data source (Places API + Street View Static API)
GOOGLE_MAPS_API_KEY=

# Programmable Search Engine id (Custom Search JSON API — web-search enrichment).
# Enable "Custom Search API" on the key + create a CSE with "Search the entire web".
GOOGLE_CSE_ID=

# Anthropic API key (sk-ant-...) — AI copy generation in the mock generator.
# Create one at console.anthropic.com. Without it, the generator uses template copy.
ANTHROPIC_API_KEY=
